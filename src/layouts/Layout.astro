---
import Footer from "../components/footer.astro";
import NavBar from "../components/nav-bar.astro";
import "../styles/global.css";

interface StructuredDataNode {
  [key: string]: unknown;
}

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  robots?: string;
  structuredData?: StructuredDataNode | StructuredDataNode[];
  /** @deprecated meta keywords ignored by modern search engines */
  keywords?: string;
}

const SITE_NAME = "Three Rivers Behavioral Health";
const DEFAULT_TITLE =
  "Three Rivers Behavioral Health | Psychiatric Inpatient, Residential & Intensive Outpatient Programs";
const DEFAULT_DESCRIPTION =
  "Three Rivers Behavioral Health offers compassionate psychiatric inpatient, residential treatment, and intensive outpatient programs for adults in West Mifflin, PA.";
const DEFAULT_OG_IMAGE = "/background/care-home-banner.webp";

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  canonicalUrl,
  ogTitle,
  ogDescription,
  ogImage = DEFAULT_OG_IMAGE,
  ogUrl,
  twitterTitle,
  twitterDescription,
  twitterImage,
  robots = "index, follow",
  structuredData,
} = Astro.props as Props;

const siteOrigin = Astro.site ?? new URL("https://trbhcares.com");

const stripTrailingSlash = (path: string) =>
  path !== "/" && path.endsWith("/") ? path.slice(0, -1) : path;

const resolvedCanonical =
  canonicalUrl ??
  new URL(stripTrailingSlash(Astro.url.pathname), siteOrigin).href;
const resolvedOgUrl = ogUrl ?? resolvedCanonical;
const resolvedOgImage = new URL(ogImage, siteOrigin).href;
const resolvedTwitterImage = new URL(
  twitterImage ?? ogImage,
  siteOrigin
).href;

const hospitalSchema: StructuredDataNode = {
  "@context": "https://schema.org",
  "@type": "Hospital",
  name: SITE_NAME,
  alternateName: "TRBH",
  url: siteOrigin.href.replace(/\/$/, ""),
  logo: new URL("/logo/trbh-logo.png", siteOrigin).href,
  image: new URL("/background/care-home-banner.webp", siteOrigin).href,
  telephone: "+1-888-391-0229",
  faxNumber: "+1-412-706-9202",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "4043 Irene St",
    addressLocality: "West Mifflin",
    addressRegion: "PA",
    postalCode: "15122",
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 40.389874,
    longitude: -79.8779095,
  },
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday",
    ],
    opens: "00:00",
    closes: "23:59",
  },
  areaServed: [
    { "@type": "City", name: "West Mifflin" },
    { "@type": "City", name: "Pittsburgh" },
    { "@type": "AdministrativeArea", name: "Allegheny County" },
    { "@type": "State", name: "Pennsylvania" },
  ],
  medicalSpecialty: ["Psychiatric", "BehavioralMedicine"],
  availableService: [
    { "@type": "MedicalTherapy", name: "Psychiatric Inpatient Treatment" },
    {
      "@type": "MedicalTherapy",
      name: "Adult Residential Mental Health Services",
    },
    { "@type": "MedicalTherapy", name: "Intensive Outpatient Program (IOP)" },
    { "@type": "MedicalProcedure", name: "EMDR Therapy" },
    { "@type": "MedicalProcedure", name: "DBT Therapy" },
  ],
  contactPoint: [
    {
      "@type": "ContactPoint",
      telephone: "+1-888-391-0229",
      contactType: "Admissions",
      areaServed: "US",
      availableLanguage: "English",
    },
    {
      "@type": "ContactPoint",
      telephone: "+1-888-391-2655",
      contactType: "Intake",
      areaServed: "US",
      availableLanguage: "English",
    },
  ],
};

const extraStructuredData: StructuredDataNode[] = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

const allStructuredData: StructuredDataNode[] = [
  hospitalSchema,
  ...extraStructuredData,
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="format-detection" content="telephone=yes" />
    <meta name="theme-color" content="#0097b2" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <link
      rel="preload"
      as="image"
      href="/background/care-home-banner.webp"
      fetchpriority="high"
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content={SITE_NAME} />
    <meta name="geo.region" content="US-PA" />
    <meta name="geo.placename" content="West Mifflin" />
    <meta name="geo.position" content="40.389874;-79.8779095" />
    <meta name="ICBM" content="40.389874, -79.8779095" />

    <link rel="canonical" href={resolvedCanonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={resolvedOgUrl} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:secure_url" content={resolvedOgImage} />
    <meta property="og:image:alt" content={ogTitle ?? title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={twitterTitle ?? ogTitle ?? title} />
    <meta
      name="twitter:description"
      content={twitterDescription ?? ogDescription ?? description}
    />
    <meta name="twitter:image" content={resolvedTwitterImage} />
    <meta name="twitter:image:alt" content={twitterTitle ?? ogTitle ?? title} />

    {
      allStructuredData.map((data) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(data)}
        />
      ))
    }

    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-2W3TT2HD37"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-2W3TT2HD37");
    </script>
  </head>

  <body class="flex flex-col min-h-screen">
    <NavBar />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
