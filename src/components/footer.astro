---
const quickLinks = [
  { label: "Patients & Visitors", href: "/patient-visitor-guide" },
  { label: "Our Programs", href: "/our-focus" },
  { label: "Location & Contact", href: "/location-contact" },
];

const resources = [
  { label: "Our Brochure", href: "/our-focus/brochure" },
  { label: "Referral Process", href: "/referral-process" },
  { label: "Price Transparency", href: "/price-transparency" },
];

const policies = [
  { label: "Notice of Nondiscrimination", href: "/notice-of-nondiscrimination" },
  { label: "Notice of Privacy Practices (HIPAA)", href: "/notice-of-privacy-practices-hipaa" },
  { label: "Notice of Private Practice", href: "/notice-of-private-practice" },
];

const year = new Date().getFullYear();
---

<footer class="bg-[#343434] text-white py-12 w-full relative bottom-0 left-0">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="mb-6 flex justify-center md:justify-start">
      <a href="/" aria-label="Three Rivers Behavioral Health home">
        <img
          src="/logo/trbh-logo-white.png"
          alt="Three Rivers Behavioral Health logo"
          width="240"
          height="144"
          class="h-36 w-auto"
          loading="lazy"
        />
      </a>
    </div>

    <div
      class="flex flex-col items-center justify-center text-center gap-12 lg:flex-row lg:justify-evenly lg:items-start lg:text-left"
    >
      <address class="not-italic space-y-4">
        <h2 class="font-bold">THREE RIVERS BEHAVIORAL HEALTH</h2>
        <p class="mt-3 text-sm leading-6">
          4043 Irene St<br />
          West Mifflin, PA 15122
        </p>
        <p class="text-sm">
          <a
            href="tel:18883910229"
            class="hover:underline"
            aria-label="Call admissions at 1-888-391-0229"
          >
            Admissions: 1-888-391-0229
          </a>
        </p>
        <p class="text-sm">
          <a
            href="tel:18883912655"
            class="hover:underline"
            aria-label="Call intake at 1-888-391-2655"
          >
            Intake: 1-888-391-2655
          </a>
        </p>
        <p class="text-sm">
          <a
            href="https://maps.google.com/?q=4043+Irene+St,+West+Mifflin,+PA+15122"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:underline"
          >
            Get Directions
          </a>
        </p>
      </address>

      <nav aria-label="Quick links" class="space-y-2">
        <h2 class="font-bold mb-3">QUICK LINKS</h2>
        <ul class="space-y-2 text-sm">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="hover:text-white font-semibold hover:font-bold transition-all duration-300"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Resources">
        <h2 class="font-bold mb-3">RESOURCES</h2>
        <ul class="space-y-2 text-sm">
          {
            resources.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="hover:text-white font-semibold hover:font-bold transition-all duration-300"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>

  <div
    class="mt-10 text-md font-semibold pt-6 text-center flex flex-col space-y-2 text-sm md:flex-row md:justify-center md:space-y-0 md:space-x-3"
  >
    {
      policies.map((link, i) => (
        <a href={link.href} class="hover:underline">
          {link.label}
          {i !== policies.length - 1 && (
            <span class="text-neutral-400"> |</span>
          )}
        </a>
      ))
    }
  </div>

  <p class="mt-6 text-center text-neutral-300 text-sm">
    &copy; {year} Three Rivers Behavioral Health. All Rights Reserved.
  </p>
</footer>
